# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Get these from: https://supabase.com → Project → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# In Supabase Dashboard → Auth → Providers → Google:
#   1. Enable Google provider
#   2. Add your Google OAuth Client ID + Secret (from console.cloud.google.com)
#   3. Add redirect URL: https://your-project-ref.supabase.co/auth/v1/callback
#
# In your Google Cloud Console → Authorized redirect URIs, add:
#   https://your-project-ref.supabase.co/auth/v1/callback
#   http://localhost:5173  (for local dev)

# ─── Phone / SMS OTP ─────────────────────────────────────────────────────────
# In Supabase Dashboard → Auth → Providers → Phone:
#   Enable Phone provider and connect your Twilio / MessageBird / Vonage account.
#   For dev/testing you can use Supabase's built-in test OTPs.
